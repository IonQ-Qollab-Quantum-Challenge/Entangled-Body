{
  "name": "entangled-body",
  "private": true,
  "version": "0.1.0",
  "description": "Entangled Body monorepo bootstrap",
  "scripts": {
    "setup": "bash ./scripts/setup.sh",
    "build": "cd apps/web && next build",
    "dev": "bash ./scripts/dev.sh",
    "web:dev": "cd apps/web && next dev -p 3000",
    "api:dev": "bash ./scripts/api-dev.sh",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/fiber": "^9.1.0",
    "@types/three": "^0.176.0",
    "codex": "^0.2.3",
    "next": "^15.3.1",
    "node": "^24.15.0",
    "pytest": "^1.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "typescript": "^5.8.3"
  }
}
